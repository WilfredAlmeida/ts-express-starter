{
  "name": "ts-express-starter",
  "version": "1.0.0",
  "description": "Starter template for TypeScript+Express",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf ./build",
    "build": "npm run clean && tsc",
    "start": "node build/index.js",
    "local": "ts-node --esm src/index.ts",
    "dev": "nodemon src -e ts,json --exec 'npm run local'"
  },
  "keywords": [],
  "author": "Wilfred Almeida",
  "license": "ISC",
  "dependencies": {
    "@types/winston": "^2.4.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.2",
    "nodemon": "^2.0.22",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.5"
  }
}